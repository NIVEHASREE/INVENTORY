NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/electroerp?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_64_chars_minimum_replace_this_now
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_64_chars_minimum_replace_this
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Client
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Shop Info (for PDF invoices)
SHOP_NAME=ElectroMart
SHOP_ADDRESS=123 Main Street, City
SHOP_PHONE=+91-9876543210
SHOP_EMAIL=info@electromart.com
SHOP_GSTIN=27AAAAA0000A1Z5
SHOP_STATE=Maharashtra
SHOP_STATE_CODE=27
